# === Convex ===
# Lo genera automáticamente `npx convex dev` en .env.local (NO commitear el real).
NEXT_PUBLIC_CONVEX_URL=

# === Solo para el despliegue en Railway ===
# Clave de despliegue de producción de Convex (para que el build ejecute `npx convex deploy`).
# CONVEX_DEPLOY_KEY=

# === Convex Auth (M2) ===
# Las variables de autenticación (JWT_PRIVATE_KEY, JWKS, SITE_URL, CRM_SEED_PW_*, CRM_ALLOW_SEED)
# NO van aquí: viven en el deployment de Convex (`npx convex env set …`). Ver DEPLOY.md.
